# Spring
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# DigitalOcean Managed Postgres
DB_HOST=your-db-host.db.ondigitalocean.com
DB_PORT=25060
DB_NAME=defaultdb
DB_USER=doadmin
DB_PASSWORD=your-password-here
DB_SSLMODE=require

# Upstream LLM endpoints
PRIMARY_LLM_URL=http://localhost:8080/mock/primary
CANDIDATE_LLM_URL=http://localhost:8080/mock/candidate
PRIMARY_LLM_TIMEOUT=10s
CANDIDATE_LLM_TIMEOUT=30s

# Embedded mock controllers (local/demo only — keep false in prod)
MOCK_LLM_ENABLED=true
MOCK_PRIMARY_DELAY_MS=0
MOCK_CANDIDATE_DELAY_MS=0
MOCK_CANDIDATE_MISMATCH=false

# GitHub Actions CD secrets (Settings → Secrets):
# DOCR_TOKEN, DOCR_REGISTRY=llm-proxy-server, DROPLET_HOST, DROPLET_USER, DROPLET_PASSWORD
# Droplet runtime env file: /opt/llm-proxy/.env
